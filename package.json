{
  "name": "textrpg",
  "version": "1.0.0",
  "description": "Choice-driven survival text RPG MVP.",
  "main": "src/server.ts",
  "scripts": {
    "build": "tsc --outDir .server-dist --rootDir src",
    "dev": "tsx watch src/server.ts",
    "start": "npm run build && node .server-dist/server.js",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx src/db/init.ts",
    "content:validate": "tsx -e \"import { validateContent } from './src/game/data/registry'; validateContent(); console.log('content ok');\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SeoulKing/textRPG.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/SeoulKing/textRPG/issues"
  },
  "homepage": "https://github.com/SeoulKing/textRPG#readme",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.0.0",
    "fastify": "^5.8.2",
    "honeycomb-grid": "^4.1.5",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "@types/pg": "^8.18.0",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
